{
  "app": {
    "window_width": 540,
    "window_height": 960,
    "ref_width": 1080,
    "ref_height": 1920,
    "camera_resolution": "1920x1080",
    "countdown_seconds": 5
  },
  "overlays": [
    {
      "slot": 0,
      "name": "Player 1",
      "video_path": "assets/players/player1.mov",
      "x": 0,
      "y": 0,
      "w": 540,
      "h": 960,
      "opacity": 1.0
    },
    {
      "slot": 1,
      "name": "Player 2",
      "video_path": "assets/players/player2.mov",
      "x": 200,
      "y": 400,
      "w": 200,
      "h": 300,
      "opacity": 0.9
    },
    {
      "slot": 2,
      "name": "Player 3",
      "video_path": "assets/players/player3.mov",
      "x": 320,
      "y": 500,
      "w": 150,
      "h": 250,
      "opacity": 0.85
    }
  ],
  "paths": {
    "output_dir": "output",
    "videos_dir": "assets/videos",
    "photos_dir": "assets/photos",
    "temp_dir": "temp"
  },
  "network": {
    "upload_enabled": true,
    "server_url": "https://api.stadium.local",
    "upload_endpoint": "/api/photo/upload",
    "timeout_seconds": 30
  }
}
