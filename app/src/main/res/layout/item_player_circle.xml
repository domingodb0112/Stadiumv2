<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp">

        <!-- Ring de selección (fondo verde, visible solo al seleccionar) -->
        <View
            android:id="@+id/v_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_ring_selected"
            android:visibility="invisible" />

        <!-- Foto circular del jugador — Usando recortes estándar por petición del usuario -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_player"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImageStyle" />

        <!-- Checkmark de selección -->
        <ImageView
            android:id="@+id/iv_check"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_check_circle"
            android:visibility="invisible" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium" />

</LinearLayout>
