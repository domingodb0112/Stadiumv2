<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Tema principal de Stadium v2.
        Hereda de Theme.MaterialComponents para que FloatingActionButton,
        MaterialButton y demás Material Components se inflen sin errores.
    -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryVariant">@color/brand_green_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/brand_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
